{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@plannotator/opencode@latest"
  ],
  "agent": {
    "build": {
      "mode": "primary"
    },
    "plan": {
      "mode": "primary"
    }
  },
  "permission": {
    "read": {
      "*.env": "deny",
      "*.env.*": "deny",
      ".envrc": "deny",
      "*.env.example": "allow"
    }
  },
  "mcp": {
    "docker": {
      "type": "local",
      "command": [
        "docker",
        "mcp",
        "gateway",
        "run"
      ],
      "enabled": true
    }
  }
}
