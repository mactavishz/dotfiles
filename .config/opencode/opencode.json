{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@plannotator/opencode@latest"
  ],
  "agent": {
    "build": {
      "mode": "primary",
      "model": "github-copilot/gpt-5.3-codex"
    },
    "plan": {
      "mode": "primary",
      "model": "github-copilot/gpt-5.3-codex"
    }
  },
  "mcp": {
    "docker": {
      "type": "local",
      "command": [
        "docker",
        "mcp",
        "gateway",
        "run"
      ],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    }
  }
}
